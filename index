<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@400;700;800&display=swap" rel="stylesheet"/>
<style>
  :root {
    --neon: #39FF14;
    --neon-dim: #1a7a09;
    --bg: #0a0a0a;
    --bg2: #111111;
    --bg3: #181818;
    --border: #222222;
    --text: #e8e8e8;
    --muted: #888888;
    --mono: 'Share Tech Mono', monospace;
    --sans: 'Syne', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    overflow-x: hidden;
  }

  /* SCANLINE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none;
    z-index: 9999;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 4rem;
    background: rgba(10,10,10,0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: var(--mono);
    color: var(--neon);
    font-size: 1rem;
    letter-spacing: 0.1em;
  }
  .nav-links { display: flex; gap: 2.5rem; }
  .nav-links a {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--neon); }

  /* SECTIONS */
  section { padding: 7rem 4rem; max-width: 1100px; margin: 0 auto; }

  /* HERO */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 8rem;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }
  .hero-tag {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--neon);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hero-tag::before {
    content: '';
    width: 32px; height: 1px;
    background: var(--neon);
  }
  h1 {
    font-size: clamp(3.5rem, 7vw, 7rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.2rem;
  }
  h1 span { color: var(--neon); }
  .hero-sub {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--muted);
    margin-top: 2rem;
    margin-bottom: 3rem;
    max-width: 520px;
    line-height: 1.7;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn {
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-block;
  }
  .btn-primary {
    background: var(--neon);
    color: #000;
    font-weight: 700;
  }
  .btn-primary:hover { background: #fff; }
  .btn-outline {
    border: 1px solid var(--border);
    color: var(--muted);
  }
  .btn-outline:hover { border-color: var(--neon); color: var(--neon); }

  .hero-stats {
    display: flex;
    gap: 3rem;
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }
  .stat-num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--neon);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 0.4rem;
  }

  /* BIG GRID BACKGROUND NUMBER */
  .hero-bg-text {
    position: absolute;
    right: -2rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 30vw;
    font-weight: 800;
    color: rgba(57,255,20,0.02);
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  /* SECTION HEADERS */
  .section-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--neon);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
    line-height: 1.1;
  }

  /* EXPERIENCE */
  .exp-list { display: flex; flex-direction: column; gap: 0; }
  .exp-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }
  .exp-item:hover { background: rgba(57,255,20,0.02); }
  .exp-date {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    padding-top: 0.25rem;
    letter-spacing: 0.05em;
  }
  .exp-role {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .exp-company {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--neon);
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }
  .exp-bullets { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .exp-bullets li {
    font-size: 0.9rem;
    color: var(--muted);
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.6;
  }
  .exp-bullets li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--neon);
  }

  /* PROJECT */
  .project-card {
    border: 1px solid var(--border);
    background: var(--bg2);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }
  .project-card:hover { border-color: var(--neon-dim); }
  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--neon);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .project-card:hover::before { transform: scaleX(1); }
  .project-num {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--neon-dim);
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
  }
  .project-title {
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .project-status {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--neon);
    background: rgba(57,255,20,0.08);
    border: 1px solid rgba(57,255,20,0.2);
    padding: 0.2rem 0.7rem;
    display: inline-block;
    margin-bottom: 1.5rem;
    letter-spacing: 0.1em;
  }
  .project-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .tech-tag {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.25rem 0.6rem;
    letter-spacing: 0.08em;
  }
  .project-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .feature {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .feature-dot {
    width: 6px; height: 6px;
    background: var(--neon);
    flex-shrink: 0;
    margin-top: 0.45rem;
  }
  .feature-text { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }

  /* SKILLS */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .skill-group {
    background: var(--bg);
    padding: 2rem;
  }
  .skill-group-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--neon);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }
  .skill-items { display: flex; flex-direction: column; gap: 0.5rem; }
  .skill-item {
    font-size: 0.9rem;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .skill-item::before { content: '—'; color: var(--neon-dim); font-size: 0.75rem; }

  /* CERTS */
  .certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .cert-item {
    border: 1px solid var(--border);
    padding: 1.5rem;
    background: var(--bg2);
    transition: border-color 0.2s;
  }
  .cert-item:hover { border-color: var(--neon-dim); }
  .cert-issuer {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--neon);
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
  }
  .cert-name { font-size: 0.9rem; font-weight: 700; line-height: 1.4; }

  /* CONTACT */
  #contact {
    background: var(--bg2);
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 7rem 4rem;
  }
  .contact-inner { max-width: 600px; margin: 0 auto; }
  .contact-email {
    font-family: var(--mono);
    font-size: 1.2rem;
    color: var(--neon);
    margin: 2rem 0;
    letter-spacing: 0.05em;
  }
  .contact-links { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; }
  .contact-link {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.1em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .contact-link:hover { color: var(--neon); border-color: var(--neon); }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  footer p {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--muted);
  }
  footer span { color: var(--neon); }

  /* CURSOR LINE ANIMATION */
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .cursor { display: inline-block; width: 3px; height: 1em; background: var(--neon); vertical-align: text-bottom; animation: blink 1s step-end infinite; margin-left: 4px; }

  /* FADE IN */
  @keyframes fadeUp { from { opacity:0; transform: translateY(30px); } to { opacity:1; transform: translateY(0); } }
  .fade-up { animation: fadeUp 0.8s ease forwards; }
  .delay-1 { animation-delay: 0.1s; opacity: 0; }
  .delay-2 { animation-delay: 0.25s; opacity: 0; }
  .delay-3 { animation-delay: 0.4s; opacity: 0; }
  .delay-4 { animation-delay: 0.55s; opacity: 0; }

  /* IELTS SCORES */
  .scores-row {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  .score-box {
    border: 1px solid var(--border);
    padding: 1rem 1.5rem;
    text-align: center;
    background: var(--bg2);
  }
  .score-val { font-size: 2rem; font-weight: 800; color: var(--neon); line-height: 1; }
  .score-sub { font-family: var(--mono); font-size: 0.65rem; color: var(--muted); margin-top: 0.3rem; letter-spacing: 0.1em; }

  @media (max-width: 700px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { gap: 1.5rem; }
    section { padding: 5rem 1.5rem; }
    #hero { padding: 8rem 1.5rem 4rem; }
    .exp-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .project-features { grid-template-columns: 1fr; }
    footer { flex-direction: column; gap: 0.5rem; text-align: center; padding: 1.5rem; }
    h1 { font-size: 3rem; }
  }
</style>
</head>
